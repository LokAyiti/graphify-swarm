# =============================================================================
# Graphify — Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
# =============================================================================

# =============================================================================
# QDRANT VECTOR STORE
# =============================================================================
# Option A — Local Docker (default, free, works offline)
# Requires: docker compose up -d
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Option B — Qdrant Cloud (team sharing, accessible from any machine)
# Get your cluster URL + key from https://cloud.qdrant.io
# QDRANT_URL=https://<cluster-id>.<region>.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=your-qdrant-api-key

# =============================================================================
# LLM PROVIDERS — set ONE or more; graphify auto-detects in this priority order:
#   Databricks → OpenAI → Anthropic → Google → Ollama (local fallback)
# =============================================================================

# ── Databricks (Azure-hosted Claude) ─────────────────────────────────────────
# DATABRICKS_TOKEN=dapi...
# DATABRICKS_SONNET_ENDPOINT=https://adb-XXXXXXXXXXXXXXXXX.X.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-6/invocations
# DATABRICKS_OPUS_ENDPOINT=https://adb-XXXXXXXXXXXXXXXXX.X.azuredatabricks.net/serving-endpoints/databricks-claude-opus-4-6/invocations

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Docs: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# ── Anthropic Claude (direct API) ────────────────────────────────────────────
# Docs: https://console.anthropic.com/keys
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Docs: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIza...

# ── Ollama (local, no key needed) ────────────────────────────────────────────
# Install: https://ollama.com  |  Start: ollama serve  |  Pull: ollama pull llama3
# No environment variable required — Ollama is the automatic fallback.
