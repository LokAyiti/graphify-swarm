# =============================================================================
# Graphify — Qdrant connection settings
# =============================================================================
# Only ONE option should be active at a time.
# Comment out the block you are NOT using.
# =============================================================================

# ── Option A: Local Docker (ACTIVE — default) ────────────────────────────────
# Requires: docker compose up -d   (from this folder)
# Free, works offline, data lives on this machine only.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Option B: Qdrant Cloud ───────────────────────────────────────────────────
# Accessible from any machine, good for team sharing.
# Steps to activate:
#   1. Regenerate your API key in https://cloud.qdrant.io  → API Keys
#   2. Comment out Option A above
#   3. Uncomment the two lines below and paste your new key
# QDRANT_URL=https://737db0a9f.us-east-1-1.aws.cloud.qdrant.io:6333
# QDRANT_API_KEY=

# =============================================================================
# LLM Provider Settings
# =============================================================================
# graphify auto-detects which provider to use in this priority order:
#   Databricks → OpenAI → Anthropic → Google → Ollama (local fallback)
#
# Set ONLY the keys for the provider(s) you want to use.
# Leave others commented out to skip them.
# =============================================================================

# ── Databricks (Claude Sonnet / Opus via Azure Databricks) ──────────────────
DATABRICKS_TOKEN=dapi2c08xxxxxxxxxxxxxxxx5b-3
#DATABRICKS_SONNET_ENDPOINT=https://adb-12x5.5.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-5/invocations
DATABRICKS_SONNET_ENDPOINT=https://adb-13845.5.azuredatabricks.net/serving-endpoints/databricks-claude-sonnet-4-6/invocations
DATABRICKS_OPUS_ENDPOINT=https://adb-13845.5.azuredatabricks.net/serving-endpoints/databricks-claude-opus-4-6/invocations

# ── OpenAI (ChatGPT) ─────────────────────────────────────────────────────────
# Usage: graphify ask "q" --provider openai --llm gpt-4o
# OPENAI_API_KEY=sk-...

# ── Anthropic (Claude direct API) ────────────────────────────────────────────
# Usage: graphify ask "q" --provider anthropic --llm claude-3-5-sonnet-latest
# ANTHROPIC_API_KEY=sk-ant-...

# ── Google (Gemini) ──────────────────────────────────────────────────────────
# Usage: graphify ask "q" --provider google --llm gemini-1.5-pro
# GOOGLE_API_KEY=AIza...
